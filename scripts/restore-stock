#!/bin/bash
set -e

# Restore stock ASIAIR firmware from backup.
#
# Two modes:
#   1. Rootfs only (default) — restores just partition 7.
#   2. Full restore — restores bootloader + all partitions.
# Both work in Loader or Maskrom mode.
#
# Usage:
#   sudo scripts/restore-stock          # rootfs only
#   sudo scripts/restore-stock --full   # full restore (all partitions)

REPODIR="$(cd "$(dirname "$0")/.." && pwd)"
TOOL="$REPODIR/rk-flashtool"
BACKUP="${BACKUP_DIR:-$REPODIR/asiair-backup}"

source "$REPODIR/scripts/lib/gpt.sh"

FULL_RESTORE=false
if [ "${1:-}" = "--full" ]; then
    FULL_RESTORE=true
fi

if [ ! -x "$TOOL" ]; then
    echo "rk-flashtool not found. Build it first:"
    echo "  ./autogen.sh && ./configure && make"
    exit 1
fi

# --- Verify backup ---

find_backup() {
    ls -1t "$BACKUP"/*_"$1" 2>/dev/null | head -1
}

ROOTFS=$(find_backup "p7_rootfs.bin")

if [ -z "$ROOTFS" ]; then
    echo "ERROR: Stock rootfs backup not found in: $BACKUP"
    echo "Cannot restore without a backup of partition 7."
    exit 1
fi

if $FULL_RESTORE; then
    BOOTLOADER=$(find_backup "bootloader_pre_partition.bin")
    UBOOT=$(find_backup "p1_uboot.bin")
    MISC=$(find_backup "p2_misc.bin")
    BOOT=$(find_backup "p3_boot.bin")
    RECOVERY=$(find_backup "p4_recovery.bin")
    ASIAIR_HDR=$(find_backup "p5_asiair_header.bin")
    PI_PART=$(find_backup "p6_pi.bin")

    MISSING=""
    [ -z "$BOOTLOADER" ] && MISSING="$MISSING  bootloader_pre_partition.bin\n"
    [ -z "$UBOOT" ] && MISSING="$MISSING  p1_uboot.bin\n"
    [ -z "$BOOT" ] && MISSING="$MISSING  p3_boot.bin\n"

    if [ -n "$MISSING" ]; then
        echo "ERROR: Full restore requires these backup files in: $BACKUP"
        echo -e "$MISSING"
        echo "Run scripts/backup first, or use rootfs-only restore (without --full)."
        exit 1
    fi
fi

# --- Read partition offsets from GPT backup ---

GPT_FILE=$(find_gpt_backup "$BACKUP")
if [ -z "$GPT_FILE" ]; then
    echo "ERROR: GPT backup (gpt_primary.bin) not found in: $BACKUP"
    echo "Cannot determine partition offsets without a GPT backup."
    exit 1
fi

P2_START=$(gpt_part_start "$GPT_FILE" 2)
P4_START=$(gpt_part_start "$GPT_FILE" 4)
P5_START=$(gpt_part_start "$GPT_FILE" 5)
P6_START=$(gpt_part_start "$GPT_FILE" 6)
P7_START=$(gpt_part_start "$GPT_FILE" 7)

if [ "$P7_START" -eq 0 ]; then
    echo "ERROR: Could not read partition 7 offset from GPT backup."
    exit 1
fi

echo "Partition offsets from GPT backup:"
printf "  p2 (misc):     sector %d (0x%X)\n" "$P2_START" "$P2_START"
printf "  p4 (recovery): sector %d (0x%X)\n" "$P4_START" "$P4_START"
printf "  p5 (asiair):   sector %d (0x%X)\n" "$P5_START" "$P5_START"
printf "  p6 (pi):       sector %d (0x%X)\n" "$P6_START" "$P6_START"
printf "  p7 (rootfs):   sector %d (0x%X)\n" "$P7_START" "$P7_START"
echo ""

# --- Verify backup sizes (sanity check) ---

check_size() {
    local file="$1"
    local min_bytes="$2"
    local label="$3"
    local actual
    actual=$(stat -c%s "$file" 2>/dev/null || echo 0)
    if [ "$actual" -lt "$min_bytes" ]; then
        echo "WARNING: $label backup looks too small ($actual bytes)."
        echo "  File: $file"
        echo "  This may indicate a corrupted or incomplete backup."
        read -rp "  Continue anyway? [y/N] " answer
        case "$answer" in
            [yY]*) ;;
            *) echo "Aborted."; exit 1 ;;
        esac
    fi
}

check_size "$ROOTFS" 1000000000 "Rootfs (p7)"
if $FULL_RESTORE; then
    check_size "$BOOTLOADER" 1000000 "Bootloader"
    check_size "$UBOOT" 1000000 "U-Boot (p1)"
    check_size "$BOOT" 10000000 "Boot image (p3)"
fi

# --- Begin restore ---

if $FULL_RESTORE; then
    echo "=== Full Stock Restore ==="
    echo ""
    echo "This will restore the entire stock firmware from your backup:"
    echo "  - Bootloader (pre-partition area, includes GPT)"
    echo "  - U-Boot (p1)"
    [ -n "$MISC" ] && echo "  - misc (p2)"
    echo "  - Boot image (p3)"
    [ -n "$RECOVERY" ] && echo "  - Recovery (p4)"
    [ -n "$ASIAIR_HDR" ] && echo "  - ASIAIR VFAT header (p5)"
    [ -n "$PI_PART" ] && echo "  - /home/pi (p6)"
    echo "  - Rootfs (p7)"
    echo ""

    $TOOL ld 2>/dev/null | grep -q "Loader\|Maskrom" || {
        echo "No ASIAIR found in Loader or Maskrom mode."
        echo ""
        echo "To enter Loader mode: hold the reset button while powering on."
        echo "To enter Maskrom: power off, open enclosure, short eMMC CLK, power on."
        exit 1
    }

    if $TOOL ld 2>/dev/null | grep -q "Maskrom"; then
        echo "Device in Maskrom — loading DDR/SPL..."
        LOADER=""
        if [ -f "$REPODIR/blobs/rk356x_spl_loader_v1.23.114.bin" ]; then
            LOADER="$REPODIR/blobs/rk356x_spl_loader_v1.23.114.bin"
        elif [ -f "$(dirname "$REPODIR")/rkbin/rk356x_spl_loader_v1.23.114.bin" ]; then
            LOADER="$(dirname "$REPODIR")/rkbin/rk356x_spl_loader_v1.23.114.bin"
        fi
        if [ -z "$LOADER" ]; then
            echo "Loader blob not found in blobs/ directory."
            exit 1
        fi
        $TOOL db "$LOADER"
        sleep 2
    fi

    echo "Restoring bootloader (pre-partition area)..."
    $TOOL wl 0 "$BOOTLOADER"
    sleep 3

    echo "Restoring U-Boot (p1)..."
    $TOOL wl 0x4000 "$UBOOT"
    sleep 3

    if [ -n "$MISC" ]; then
        echo "Restoring misc (p2)..."
        $TOOL wl "$P2_START" "$MISC"
        sleep 3
    fi

    echo "Restoring boot image (p3)..."
    $TOOL wl 0x8000 "$BOOT"
    sleep 3

    if [ -n "$RECOVERY" ]; then
        echo "Restoring recovery (p4)..."
        $TOOL wl "$P4_START" "$RECOVERY"
        sleep 3
    fi

    if [ -n "$ASIAIR_HDR" ]; then
        echo "Restoring ASIAIR VFAT header (p5)..."
        $TOOL wl "$P5_START" "$ASIAIR_HDR"
        sleep 3
    fi

    if [ -n "$PI_PART" ]; then
        echo "Restoring /home/pi (p6)..."
        $TOOL wl "$P6_START" "$PI_PART"
        sleep 3
    fi

    echo "Restoring rootfs (p7) — this will take several minutes..."
    $TOOL wl "$P7_START" "$ROOTFS"

else
    echo "=== Restore Stock Rootfs ==="
    echo ""
    echo "This will restore the stock rootfs (partition 7) from your backup."
    echo "All OpenAstro Linux data will be overwritten."
    echo "The boot chain is not modified."
    echo ""

    $TOOL ld 2>/dev/null | grep -q "Loader\|Maskrom" || {
        echo "No ASIAIR found in Loader or Maskrom mode."
        echo ""
        echo "To enter Loader mode: hold the reset button while powering on."
        exit 1
    }

    echo "Restoring stock rootfs (p7) — this will take several minutes..."
    $TOOL wl "$P7_START" "$ROOTFS"
fi

echo ""
echo "=== Restore complete. Resetting device... ==="
$TOOL rd || true

echo ""
echo "Stock ASIAIR firmware has been restored."
echo "The device will boot the original ZWO software."
echo ""
echo "  Default SSH: pi@asiair (password: raspberry)"
echo "  Requires jailbreak for SSH access."
